export SHELL="/usr/bin/zsh"

# Initialize brew PATH (Linuxbrew on workspaces, Homebrew on macOS)
for _prefix in /home/linuxbrew/.linuxbrew /opt/homebrew /usr/local; do
    [[ -x "$_prefix/bin/brew" ]] && eval "$($_prefix/bin/brew shellenv)" && break
done
unset _prefix

# Stable SSH agent socket (fixes stale SSH_AUTH_SOCK in long-running processes like Claude Code)
if [[ -n "$SSH_AUTH_SOCK" && "$SSH_AUTH_SOCK" != "$HOME/.ssh/ssh_auth_sock" ]]; then
    ln -sf "$SSH_AUTH_SOCK" "$HOME/.ssh/ssh_auth_sock" 2>/dev/null
fi
export SSH_AUTH_SOCK="$HOME/.ssh/ssh_auth_sock"

# Export current theme so remote tmux sessions can pick it up via SendEnv LC_TERMINAL_THEME
export LC_TERMINAL_THEME=$(cat "${XDG_STATE_HOME:-$HOME/.local/state}/theme" 2>/dev/null || echo "dark")

# Editor
if [[ -n $SSH_CONNECTION ]]; then
  export EDITOR='vim'
else
  export EDITOR='nvim'
fi

# Aliases
alias vim=nvim
alias peon="bash ~/.claude/hooks/peon-ping/peon.sh"
[ -f ~/.claude/hooks/peon-ping/completions.bash ] && source ~/.claude/hooks/peon-ping/completions.bash

# fzf
source <(fzf --zsh)

# Starship
eval "$(starship init zsh)"

# Zsh plugins (brew-managed with git-clone fallback for non-brew environments)
BREW_PREFIX="$(brew --prefix 2>/dev/null)"
_load_zsh_plugin() {
    local name="$1"
    if [[ -n "$BREW_PREFIX" && -f "$BREW_PREFIX/share/$name/$name.zsh" ]]; then
        source "$BREW_PREFIX/share/$name/$name.zsh"
    elif [[ -f "$HOME/.zsh/$name/$name.zsh" ]]; then
        source "$HOME/.zsh/$name/$name.zsh"
    fi
}
_load_zsh_plugin zsh-autosuggestions
_load_zsh_plugin zsh-syntax-highlighting

autoload -U compinit
if [[ -n ~/.zcompdump(#qN.mh+24) ]]; then
    compinit
else
    compinit -C
fi
source ~/.zsh/fzf-tab/fzf-tab.plugin.zsh

# Zoxide (must be last)
export _ZO_DOCTOR=0
eval "$(zoxide init zsh)"
alias cd=z
