#!/usr/bin/env bash
set -euo pipefail

ssh_dir="$HOME/.ssh"
config_file="$ssh_dir/config"
managed_include='Include ~/.ssh/config_chezmoi'
begin_marker='## BEGIN -- chezmoi'
end_marker='## END -- chezmoi'

mkdir -p "$ssh_dir"
touch "$config_file"
chmod 700 "$ssh_dir"
chmod 600 "$config_file"

tmp_file="$(mktemp)"

awk -v begin="$begin_marker" -v end="$end_marker" '
  $0 == begin {in_block=1; next}
  $0 == end {in_block=0; next}
  !in_block {print}
' "$config_file" > "$tmp_file"

{
  cat "$tmp_file"
  [[ -s "$tmp_file" ]] && echo
  echo "$begin_marker"
  echo "$managed_include"
  echo "$end_marker"
} > "$config_file"

rm -f "$tmp_file"
